# --- Auth (signed-cookie sessions) ---
# Long random string used to HMAC-sign session cookies. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=

# --- Slack "Sign in with Slack" (OpenID Connect) ---
# From your Slack app's OAuth settings. Redirect URL must be:
#   https://bash.hackclub.com/api/slack_redirect  (and http://localhost:3000/... for dev)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- Airtable (via Hack Club middleman proxy) ---
# Bearer token for middleman.hackclub.com/airtable and the Boba Bash base id.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
