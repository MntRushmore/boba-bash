# --- Session (signed cookie) ---
# Long random string used to HMAC-sign session cookies. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=

# --- Hack Club Auth (OIDC) — ORGANIZER login ---
# Self-serve register the app at https://auth.hackclub.com/developer_apps
# Register these redirect URIs exactly (no trailing slash!):
#   https://bash.hackclub.com/api/auth/callback
#   http://localhost:3000/api/auth/callback     (dev — run `bun run dev`, port 3000)
# The `address` scope is HQ-gated — ask HC staff to promote this client so we
# can read organizers' mailing address.
HCAUTH_CLIENT_ID=
HCAUTH_CLIENT_SECRET=

# --- Resend — ATTENDEE magic-link email ---
# https://resend.com — verify a sending domain (e.g. bash.hackclub.com).
# If unset in dev, the magic link is logged to the server console instead.
RESEND_API_KEY=

# --- Airtable (direct REST API) ---
# Personal access token (pat...) with data.records:read/write on the base.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# --- App ---
# Public origin used to build referral links. Defaults to the prod domain.
APP_ORIGIN=https://bash.hackclub.com
